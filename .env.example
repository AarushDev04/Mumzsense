# MumzSense deployment template
# Copy to env/.env and fill in the real values before deploying.

# LLM provider: groq_api | groq | openrouter | llama_api
LLM_PROVIDER=groq_api
GROQ_API_KEY=
LLAMA_API_KEY=

# Optional database/cache connections
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=
REDIS_URL=

# App/runtime settings
FASTAPI_ENV=production
ADMIN_TOKEN=changeme
VITE_APP_ORIGIN=http://localhost:5173