# MumzSense Frontend Environment Variables
# Copy to .env.local for local development

# Backend API URL — in development with Vite proxy, set to /api
# In production set this to the deployed backend URL.


# Vercel deployment URL (set automatically by Vercel in production)
# VITE_API_URL=https://mumzsense-api.railway.app
VITE_API_URL=http://localhost:8000